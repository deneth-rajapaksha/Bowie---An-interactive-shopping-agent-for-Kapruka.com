ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
GOOGLE_PLACES_API_KEY=
MCP_SERVER_URL=https://mcp.kapruka.com/mcp
BOWIE_API_SECRET=

# Optional. The backend falls back to an in-memory cache when these are absent.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional hot-cache controls for repeated kapruka_search_products calls.
# After the same normalized search hits this count inside the window, its compact
# result is promoted into a longer-lived cache.
SEARCH_HOT_CACHE_MIN_HITS=3
SEARCH_HOT_CACHE_WINDOW_SECONDS=3600
SEARCH_HOT_CACHE_TTL_SECONDS=21600

# Select exactly one backend LLM provider. OpenAI is the optimized/default path.
# Other available options remain: anthropic, gemini, modal, openrouter.
BOWIE_AI_PROVIDER=openai

# Optional model overrides. Leave BOWIE_* blank unless you want one model name
# to apply to whichever provider is selected.
BOWIE_FAST_MODEL=
BOWIE_SMART_MODEL=

# Optional provider-specific overrides.
ANTHROPIC_FAST_MODEL=claude-haiku-4-5
ANTHROPIC_SMART_MODEL=claude-sonnet-4-6
OPENAI_FAST_MODEL=gpt-4.1-mini
OPENAI_SMART_MODEL=gpt-4.1
GEMINI_FAST_MODEL=gemini-3.5-flash
GEMINI_SMART_MODEL=gemini-3.5-flash

# Modal vLLM/OpenAI-compatible endpoint.
# Example: https://your-workspace--bowie-vllm-serve.modal.run/v1
MODAL_OPENAI_BASE_URL=
MODAL_API_KEY=
MODAL_FAST_MODEL=bowie-modal
MODAL_SMART_MODEL=bowie-modal

# Langfuse Cloud tracing.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_ENVIRONMENT=development

# Optional Slack or Discord webhook for disliked responses with a reason.
# Langfuse remains the source of truth; this is only the admin notification path.
ADMIN_ALERT_WEBHOOK_URL=
# Optional. Auto-detected from the URL when blank. Supported values: slack, discord.
ADMIN_ALERT_WEBHOOK_TYPE=

# Optional bearer token for GET/POST /api/admin/langfuse-retention.
# Vercel Cron commonly uses CRON_SECRET; Bowie also accepts BOWIE_RETENTION_CRON_SECRET.
BOWIE_RETENTION_CRON_SECRET=
CRON_SECRET=
